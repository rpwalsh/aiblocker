# Crowd Learning Server
# Postgres connection string
DATABASE_URL=postgres://user:pass@localhost:5432/aiblocker

# Server port
PORT=8787

# PEM-encoded RSA private key for signing models (RS256)
# Generate (example):
#   openssl genrsa -out model_private.pem 2048
#   openssl rsa -in model_private.pem -pubout -out model_public.pem
MODEL_SIGNING_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
